# Copy to .env (cp .env.example .env) and fill in real values.
# Do NOT commit the real .env — it's gitignored (see .gitignore's `.env`/`*.env` rules).

# Postgres, async driver. Matches docker-compose.yml's `db` service.
DATABASE_URL=postgresql+asyncpg://keepa_scout:keepa_scout@db:5432/keepa_scout

# Redis, used as the Celery broker/result backend. Matches the `broker` service.
REDIS_URL=redis://broker:6379/0

# Comma-separated Keepa API keys (rotated on 402/429 — see ARCHITECTURE.md §4.4
# / candidate_package/KEEPA_QUICKSTART.md). The real keys assigned to this
# challenge live in candidate_package/env.example — copy them here, don't
# invent placeholders that won't actually hit the Keepa API.
KEEPA_API_KEYS=your-keepa-key-1,your-keepa-key-2

# LLM provider — OpenAI-compatible endpoint (see ARCHITECTURE.md §4.4, "换供
# 应商只换 base_url"). Using DeepSeek by default; swap base_url/model to use
# a different OpenAI-compatible provider without touching any code.
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# Auth token lifetime, in hours. See ARCHITECTURE.md §6.
TOKEN_TTL_HOURS=24

# Timezone for api/worker/beat. Celery beat's daily refresh runs at 04:00 UTC.
TZ=UTC
