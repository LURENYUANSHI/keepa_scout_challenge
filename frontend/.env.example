# Base URL of the FastAPI backend. Defaults to http://localhost:8000 in
# src/api/client.js if this var isn't set, so copying this file isn't
# strictly required for local dev — it's here so the override is discoverable.
VITE_API_BASE_URL=http://localhost:8000

# WS endpoint for the /chat page's WS /chat/stream connection. Optional —
# if unset, src/api/client.js derives it from VITE_API_BASE_URL by swapping
# http(s) for ws(s), which is correct for every setup in this repo today.
# Only set this if the WS endpoint genuinely lives on a different host.
# VITE_WS_BASE_URL=ws://localhost:8000
